# Auto-HTTPS reverse proxy for the API.
# Caddy provisions and renews a Let's Encrypt cert for {$API_DOMAIN} on its own.

{$API_DOMAIN} {
	encode gzip

	# Worker health endpoint — the worker has no public port, so expose its
	# internal HTTP health server here for external uptime monitors (UptimeRobot).
	handle /worker-health* {
		reverse_proxy worker:3002
	}

	# Everything else → tRPC / express server
	handle {
		reverse_proxy server:4000
	}

	# Basic hardening headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
