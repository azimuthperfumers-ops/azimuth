# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION ENV — copy to deploy/.env.production on the VPS and fill in.
# NEVER commit the filled file. `deploy/.env.production` is gitignored.
#
# Consumed by:
#   - docker compose (postgres creds, image registry/tag, API domain)
#   - server + worker containers (env_file: .env.production)
# ─────────────────────────────────────────────────────────────────────────────

# ── Image source (GitHub Container Registry) ─────────────────────────────────
# REGISTRY = ghcr.io/<your-github-username-or-org>  (lowercase)
REGISTRY=ghcr.io/manthan0x23
IMAGE_TAG=latest

# ── Public API hostname (Caddy gets a TLS cert for this) ─────────────────────
# Point an A record for this subdomain at the VPS IP before first `up`.
API_DOMAIN=api.yourdomain.com

# ── Datastores ───────────────────────────────────────────────────────────────
# Postgres: managed by Neon. Paste the pooled connection string, NO surrounding
# quotes and NO "DATABASE_URL=" prefix inside the value — just the URL itself.
DATABASE_URL=postgres://USER:PASS@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# Redis: runs locally in the compose stack (service name "redis"). Not managed —
# a job queue burns commands, so a metered tier isn't worth it.
REDIS_URL=redis://redis:6379

NODE_ENV=production
PORT=4000

# ── Auth (better-auth) ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=CHANGE_ME_openssl_rand_hex_32
BETTER_AUTH_URL=https://api.yourdomain.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── CORS / app URLs (the Vercel-hosted frontends) ────────────────────────────
USER_APP_URL=https://yourdomain.com
ADMIN_APP_URL=https://admin.yourdomain.com
CORS_EXTRA_ORIGINS=

# ── Cloudflare R2 (image storage) ────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Razorpay (payments) — required, server refuses to boot without these ──────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Logistics: Shiprocket — required (LOGISTICS_PROVIDER must be "shiprocket") ─
LOGISTICS_PROVIDER=shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=
SHIPROCKET_CHANNEL_ID=
SHIPROCKET_LOCATION_ID=
SHIPROCKET_WAREHOUSE_PINCODE=
SHIPROCKET_WAREHOUSE_PHONE=
SHIPROCKET_WAREHOUSE_CITY=
SHIPROCKET_WAREHOUSE_STATE=
SHIPROCKET_WAREHOUSE_ADDRESS=
SHIPROCKET_WEBHOOK_SECRET=

# ── Worker cross-link ────────────────────────────────────────────────────────
WORKER_URL=http://worker:3002

# ── Monitoring ───────────────────────────────────────────────────────────────
# Healthchecks.io dead-man's-switch. Create a free check, paste its ping URL.
# Worker pings it every 60s while consuming; missed pings → alert. Leave blank to disable.
HEALTHCHECK_URL=

# ── MSG91 (email comms) ──────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=AZIMUT
MSG91_EMAIL_DOMAIN=
MSG91_EMAIL_FROM=
# All admin alerts go here by email
ADMIN_EMAIL=
# Email template IDs (MSG91 → Email → Templates)
# Customer transactional
MSG91_EMAIL_TEMPLATE_ORDER_PLACED=
MSG91_EMAIL_TEMPLATE_ORDER_DELIVERED=
MSG91_EMAIL_TEMPLATE_REFUND=
# Auth — verification link + password-reset OTP
MSG91_EMAIL_TEMPLATE_VERIFY=
MSG91_EMAIL_TEMPLATE_OTP=
# Admin alerts
MSG91_EMAIL_TEMPLATE_ADMIN_NEW_ORDER=
MSG91_EMAIL_TEMPLATE_ADMIN_ORDER_DELIVERED=
MSG91_EMAIL_TEMPLATE_ADMIN_NEW_TICKET=
MSG91_EMAIL_TEMPLATE_ADMIN_DELIVERY_FAILED=
MSG91_EMAIL_TEMPLATE_ADMIN_REFUND=

# ── Seed admin (used once by `pnpm db:seed:admin`) ───────────────────────────
SEED_ADMIN_EMAIL=
SEED_ADMIN_NAME=
SEED_ADMIN_PASSWORD=
