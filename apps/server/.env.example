# https://console.cloud.google.com/apis/credentials — leave blank to disable Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 — https://dash.cloudflare.com → R2 → your bucket → Settings
# R2_ACCOUNT_ID    : your 32-char Cloudflare account ID
# R2_ACCESS_KEY_ID : R2 API token "Access Key ID"
# R2_SECRET_ACCESS_KEY : R2 API token "Secret Access Key"
# R2_BUCKET_NAME   : bucket name (e.g. azimuth-media)
# R2_PUBLIC_URL    : public access URL (e.g. https://pub-xxxx.r2.dev or custom domain)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

