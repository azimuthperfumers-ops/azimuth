DATABASE_URL=postgresql://postgres:postgres@localhost:5434/azimuth_perfumers
PORT=4000
REDIS_URL=redis://localhost:6379
ADMIN_APP_URL=http://localhost:3001
USER_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-32-char-random-string
# Shared secret required to register a new admin account. Keep this out of source control.
ADMIN_INVITE_CODE=admin123
BETTER_AUTH_URL=http://localhost:4000
# https://console.cloud.google.com/apis/credentials — leave blank to disable Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 — https://dash.cloudflare.com → R2 → your bucket → Settings
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Razorpay — https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Logistics provider: "delhivery" (default) | "shiprocket" | "stub"
LOGISTICS_PROVIDER=delhivery

# Delhivery Express B2C — https://one.delhivery.com → Developer Portal
DELHIVERY_TOKEN=
DELHIVERY_BASE_URL=https://staging-express.delhivery.com
DELHIVERY_CLIENT=AZIMUTHSURFACE-B2C
DELHIVERY_PICKUP_NAME=AZIMUTH SURFACE
DELHIVERY_WAREHOUSE_NAME=Azimuth Perfumers
DELHIVERY_WAREHOUSE_ADDRESS=Plot No. 14 Shitla Vihar, Foysagar Road, Chamunda Chauraha, Ajmer
DELHIVERY_WAREHOUSE_CITY=Ajmer
DELHIVERY_WAREHOUSE_STATE=Rajasthan
DELHIVERY_WAREHOUSE_PINCODE=305005
DELHIVERY_WAREHOUSE_PHONE=9680361115
# Staging only: flat rate returned when Delhivery rate API gives 0 (staging has no real rate data)
DELHIVERY_RATE_FALLBACK_INR=99
# Shared secret registered with Delhivery for scan-push webhook auth (token query param)
DELHIVERY_WEBHOOK_TOKEN=

# Shiprocket (kept for reference — swap LOGISTICS_PROVIDER to use)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=
SHIPROCKET_CHANNEL_ID=
SHIPROCKET_WAREHOUSE_PINCODE=
SHIPROCKET_WAREHOUSE_PHONE=
SHIPROCKET_WAREHOUSE_ADDRESS=
SHIPROCKET_WAREHOUSE_CITY=
SHIPROCKET_WAREHOUSE_STATE=
SHIPROCKET_LOCATION_ID=

# MSG91 — https://control.msg91.com → Settings → API Key
MSG91_AUTH_KEY=
MSG91_SENDER_ID=AZIMUT
MSG91_WHATSAPP_NUMBER=
MSG91_EMAIL_DOMAIN=
MSG91_EMAIL_FROM=

# Admin notification contacts
ADMIN_EMAIL=
ADMIN_WHATSAPP=

# SMS flow IDs (MSG91 → SMS → Flows, DLT OTP category)
MSG91_SMS_FLOW_OTP=

# WhatsApp template names (MSG91 → WhatsApp → Templates)
MSG91_WA_TEMPLATE_ORDER_PLACED=
MSG91_WA_TEMPLATE_REFUND=
MSG91_WA_TEMPLATE_ADMIN_NEW_ORDER=
MSG91_WA_TEMPLATE_ADMIN_DELIVERY_FAILED=
MSG91_WA_TEMPLATE_ADMIN_EXCHANGE_RECEIVED=

# Email template IDs (MSG91 → Email → Templates)
MSG91_EMAIL_TEMPLATE_PASSWORD_RESET=
MSG91_EMAIL_TEMPLATE_ADMIN_REFUND=
