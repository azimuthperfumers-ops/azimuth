DATABASE_URL=postgresql://postgres:postgres@localhost:5434/azimuth_perfumers
REDIS_URL=redis://localhost:6379
PORT=3002

# Razorpay — https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Logistics provider: "shiprocket" (default) | "stub"
LOGISTICS_PROVIDER=shiprocket

# Shiprocket — https://app.shiprocket.in → Settings → API
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=
SHIPROCKET_CHANNEL_ID=
SHIPROCKET_WAREHOUSE_PINCODE=
SHIPROCKET_WAREHOUSE_PHONE=
SHIPROCKET_WAREHOUSE_ADDRESS=
SHIPROCKET_WAREHOUSE_CITY=
SHIPROCKET_WAREHOUSE_STATE=
SHIPROCKET_LOCATION_ID=

# MSG91 — https://control.msg91.com → Settings → API Key
MSG91_AUTH_KEY=
MSG91_SENDER_ID=AZIMUT
MSG91_WHATSAPP_NUMBER=
MSG91_EMAIL_DOMAIN=
MSG91_EMAIL_FROM=

# Admin notification contacts
ADMIN_EMAIL=
ADMIN_WHATSAPP=

# SMS flow IDs (MSG91 → SMS → Flows, DLT OTP category)
MSG91_SMS_FLOW_OTP=

# WhatsApp template names (MSG91 → WhatsApp → Templates)
MSG91_WA_TEMPLATE_ORDER_PLACED=
MSG91_WA_TEMPLATE_REFUND=
MSG91_WA_TEMPLATE_ADMIN_NEW_ORDER=
MSG91_WA_TEMPLATE_ADMIN_DELIVERY_FAILED=
MSG91_WA_TEMPLATE_ADMIN_EXCHANGE_RECEIVED=

# Email template IDs (MSG91 → Email → Templates)
MSG91_EMAIL_TEMPLATE_PASSWORD_RESET=
MSG91_EMAIL_TEMPLATE_ADMIN_REFUND=
