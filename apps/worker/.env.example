DATABASE_URL=postgresql://postgres:postgres@localhost:5434/azimuth_perfumers
REDIS_URL=redis://localhost:6379
PORT=3002

# Razorpay — https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Logistics provider: "shiprocket" (default) | "stub"
LOGISTICS_PROVIDER=shiprocket

# Shiprocket — https://app.shiprocket.in → Settings → API
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=
SHIPROCKET_CHANNEL_ID=
SHIPROCKET_WAREHOUSE_PINCODE=
SHIPROCKET_WAREHOUSE_PHONE=
SHIPROCKET_WAREHOUSE_ADDRESS=
SHIPROCKET_WAREHOUSE_CITY=
SHIPROCKET_WAREHOUSE_STATE=
SHIPROCKET_LOCATION_ID=

# MSG91 — https://control.msg91.com → Settings → API Key
MSG91_AUTH_KEY=
MSG91_SENDER_ID=AZIMUT
MSG91_EMAIL_DOMAIN=
MSG91_EMAIL_FROM=

# Admin notification contact — all admin alerts go here by email
ADMIN_EMAIL=

# Email template IDs (MSG91 → Email → Templates)
# Customer transactional
MSG91_EMAIL_TEMPLATE_ORDER_PLACED=
MSG91_EMAIL_TEMPLATE_ORDER_DELIVERED=
MSG91_EMAIL_TEMPLATE_REFUND=
# Auth — verification link + password-reset OTP
MSG91_EMAIL_TEMPLATE_VERIFY=
MSG91_EMAIL_TEMPLATE_OTP=
# Admin alerts
MSG91_EMAIL_TEMPLATE_ADMIN_NEW_ORDER=
MSG91_EMAIL_TEMPLATE_ADMIN_ORDER_DELIVERED=
MSG91_EMAIL_TEMPLATE_ADMIN_NEW_TICKET=
MSG91_EMAIL_TEMPLATE_ADMIN_DELIVERY_FAILED=
MSG91_EMAIL_TEMPLATE_ADMIN_REFUND=

# App origins — deep links inside emails
USER_APP_URL=http://localhost:3000    # customer "rate your purchase" link
ADMIN_APP_URL=http://localhost:3001   # admin "view order/ticket" links
